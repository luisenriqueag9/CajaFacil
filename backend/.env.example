# Aplicación
APP_NAME="CajaFácil POS"
ENV="development"
DEBUG=true
LOG_LEVEL="info"

# Base de datos activa
# Opciones soportadas: sqlite, postgres
DB_PROVIDER="sqlite"

# SQLite Configuración
SQLITE_DB_PATH="./caja_facil.db"

# PostgreSQL Configuración
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="secret_password"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="caja_facil_db"

# Seguridad (Marcadores de posición)
SECRET_KEY="super_secret_cryptographic_key_here"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
